.playwright-mcp/
suggestions.md

# Node
node_modules/
# Lockfiles are intentionally NOT committed. This repo's package.json is a
# template manifest — end users install these deps in their own Remotion
# project (created via `npx create-video`) where they generate their own
# yarn.lock / package-lock.json. Committing a lockfile here would pin
# contributors to one package manager without benefiting end users.
# Contributors running the skill's own scripts can `yarn install` locally
# (project uses Yarn per package.json `packageManager` field).
package-lock.json
yarn.lock
dist/
out/
bundle/

# Design references
design_references/

# Video outputs
videos/
*.wav
*.mp4
*.srt

# Keep assets
!assets/*.mp4
!assets/*.mp3

# User preferences (learned, auto-created from template)
user_prefs.json

# Global phoneme dictionary (user-customized, auto-created from template)
phonemes.json

# Design reference binary assets (frames, covers)
design_references/*/frames/
design_references/*/cover.*

# Update check throttle
.last_update_check

# Python
__pycache__/
*.pyc
.pytest_cache/

# Temp files
part_*.wav
concat_list.txt

# Internal docs (not for users)
docs/
AGENTS.md

# Runtime Remotion source (copies of templates + per-video compositions)
src/

# Worktrees
.worktrees/
logs/
public/
CLAUDE.md

# Local dev (pytest path setup, not needed by end users)
conftest.py
tests/
