# TTS Configuration (all synthesis routes through the ttsCN component skill)
TTS_BACKEND=edge          # Options: edge, azure, doubao, cosyvoice, tencent, baidu, minimax, xunfei, elevenlabs, openai, google
TTS_RATE="+5%"
# TTS_VOICE=              # Optional voice override; unset = ttsCN per-platform default
# TTS_STYLE=gentle        # Azure express-as style (azure only; empty disables the wrapper)
# TTSCN_HOME=             # ttsCN install root (default: ~/.claude/skills/ttsCN)
# TTSCN_PLATFORM=edge     # Platform for the legacy TTS_BACKEND=ttscn alias only

# Azure Speech (if using azure backend)
# AZURE_SPEECH_KEY=your-key-here
# AZURE_SPEECH_REGION=eastasia

# Volcengine Doubao (if using doubao backend)
# VOLCENGINE_APPID=your-appid
# VOLCENGINE_ACCESS_TOKEN=your-token
# VOLCENGINE_TIMEOUT_SEC=30   # Optional per-request timeout override

# Alibaba CosyVoice (if using cosyvoice backend)
# DASHSCOPE_API_KEY=your-key

# Tencent Cloud (if using tencent backend)
# TENCENT_SECRET_ID=your-id
# TENCENT_SECRET_KEY=your-key

# Baidu AI (if using baidu backend)
# BAIDU_APP_ID=your-appid
# BAIDU_API_KEY=your-key
# BAIDU_SECRET_KEY=your-secret

# MiniMax (if using minimax backend)
# MINIMAX_API_KEY=your-key

# iFlytek Xunfei (if using xunfei backend)
# XUNFEI_APP_ID=your-appid
# XUNFEI_API_KEY=your-key
# XUNFEI_API_SECRET=your-secret

# ElevenLabs (if using elevenlabs backend)
# ELEVENLABS_API_KEY=your-key

# OpenAI (if using openai backend)
# OPENAI_API_KEY=your-key

# Google Cloud TTS (if using google backend)
# GOOGLE_TTS_API_KEY=your-key

# Optional: AI thumbnails
# GEMINI_API_KEY=your-key
# DASHSCOPE_API_KEY=your-key   (shared with CosyVoice)
